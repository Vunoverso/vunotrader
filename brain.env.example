# Arquivo de configuração do VunoTrader Brain (Python)
# Copie este arquivo para brain.env e preencha os valores reais.
# NUNCA versione brain.env — ele contém credenciais sensíveis.

# ─── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://mztrtovhjododrkzkehk.supabase.co
# Obter em: Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_A_SERVICE_ROLE_KEY

# ─── Identificação do usuário/organização ──────────────────────────
# UUID gerado após criar conta no painel Vuno Trader.
# Obter em: Supabase → Table Editor → user_profiles → id (da sua conta)
BRAIN_USER_ID=COLE_AQUI_O_UUID_DO_USUARIO
# Obter em: Supabase → Table Editor → organizations → id (da sua org)
BRAIN_ORG_ID=COLE_AQUI_O_UUID_DA_ORGANIZACAO

# ─── MetaTrader 5 local (CLI Python direto) ───────────────────────
# Opcional. Usado por scripts/mt5_cmd_bot.py para conectar direto no terminal MT5.
# Em Windows, o path normalmente aponta para terminal64.exe.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_TIMEOUT_MS=60000
MT5_MAGIC=20260331
MT5_DEVIATION=20
MT5_TIMEFRAME=M5

# ─── Notícias financeiras (contexto macro para o Brain) ─────────
# A chave deve ser mantida apenas em ambiente local/seguro.
ENABLE_FIN_NEWS=1
FIN_NEWS_API_KEY=COLE_AQUI_SUA_API_DE_NOTICIAS
# off: desativa noticias | shadow: apenas mede impacto (recomendado) | assist: pode alterar risco/sinal
FIN_NEWS_MODE=shadow
FIN_NEWS_API_URL_TEMPLATE=https://api.apitube.io/v1/news/everything?query={query}&language={language}&limit={limit}
FIN_NEWS_API_URL_TEMPLATES=https://api.apitube.io/v1/news/everything?query={query}&language={language}&limit={limit},https://api.apitube.io/v1/news/everything?q={query}&language={language}&limit={limit},https://api.apitube.io/v1/news?query={query}&language={language}&limit={limit},https://api.apitube.io/v1/news?q={query}&language={language}&limit={limit}
FIN_NEWS_TIMEOUT_SEC=3.0
FIN_NEWS_CACHE_SEC=120
FIN_NEWS_LANGUAGE=pt
FIN_NEWS_MIN_ARTICLES=3
# So influencia em assist quando confianca de noticia excede este limiar
FIN_NEWS_MIN_CONFIDENCE_TO_INFLUENCE=0.80
# Em conflito: reduz risco em 30% (0.30)
FIN_NEWS_CONFLICT_RISK_REDUCTION=0.30
# Em alinhamento: aumenta risco em 10% (0.10)
FIN_NEWS_ALIGNMENT_RISK_BOOST=0.10
# Se 1, permite bloquear sinal em conflito muito forte (assist only)
FIN_NEWS_BLOCK_ON_CONFLICT=0
FIN_NEWS_BLOCK_CONFIDENCE=0.92
