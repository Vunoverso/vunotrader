# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Frontend-compatible keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# AI
OPENAI_API_KEY=sk-proj-xxx

# Backend
APP_ENV=development
SERVICE_NAME=vuno-trader-saas
SERVICE_VERSION=0.3.0
API_HOST=127.0.0.1
API_PORT=8000
UVICORN_WORKERS=2

# Database (sqlite ou postgres/supabase)
DB_DRIVER=sqlite
# DATABASE_URL=postgresql://postgres:senha@db.seu-projeto.supabase.co:5432/postgres
# SQLITE_DB_PATH=./runtime/vuno_saas.db

CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:3000
LOG_LEVEL=INFO
LOG_JSON=false
REQUEST_LOG_EXCLUDE_PATHS=/api/health
ERROR_ALERT_WEBHOOK_URL=
ERROR_ALERT_TIMEOUT_SECONDS=2.5

SESSION_HOURS=8
SESSION_COOKIE_NAME=vuno_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_PATH=/
# SESSION_COOKIE_DOMAIN=seudominio.com
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_BLOCK_MINUTES=20

# Backup
BACKUP_RETENTION_DAYS=14
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
PG_MAINTENANCE_DB=postgres
